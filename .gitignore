# ====================================================
# .gitignore — Portfolio (Muhammad Khuzaima)
# ====================================================

# ---------- OS junk ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/

# ---------- Editors / IDEs ----------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
*.code-workspace
.history/

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Node / package managers ----------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------- Build / dist ----------
dist/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/
.vite/

# ---------- Env / secrets ----------
.env
.env.local
.env.*.local

# ---------- Misc ----------
*.bak
*.tmp
*.orig
*.rej
.swc/
